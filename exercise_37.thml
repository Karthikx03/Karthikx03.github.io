<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Circle Properties</title>
</head>
<body>

    <h1>Circle Properties Calculator</h1>
    <p>Open your browser console to view the output, or look at the alerts on the page.</p>

    <script>
        // Function 1: Pass the radius, calculate circumference, and output the text
        function calcCircumfrence(radius) {
            let circumference = 2 * Math.PI * radius;
            document.write("<p>The circumference is " + circumference + "</p>");
            console.log("The circumference is " + circumference);
        }

        // Function 2: Pass the radius, calculate area, and output the text
        function calcArea(radius) {
            let area = Math.PI * Math.pow(radius, 2);
            document.write("<p>The area is " + area + "</p>");
            console.log("The area is " + area);
        }

        // Run both functions automatically with a test radius of 5
        let radius = 5;
        calcCircumfrence(radius);
        calcArea(radius);
    </script>

</body>
</html>
